{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a system user with role and department information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "department": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Document": {
      "title": "Document",
      "description": "Represents a stored document in the archive.",
      "type": "object",
      "properties": {
        "docId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "department": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["Active", "Archived", "Pending"] },
        "uploadedBy": { "type": "string" },
        "uploaderId": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "fileSize": { "type": "number" },
        "fileType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["docId", "title", "category", "department", "uploaderId"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Records all actions taken on documents for security and tracking.",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "documentId": { "type": "string" },
        "documentTitle": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "string" }
      },
      "required": ["action", "userId", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and permissions."
    },
    "documents/{documentId}": {
      "schema": "Document",
      "description": "Stored documents metadata."
    },
    "logs/{logId}": {
      "schema": "AuditLog",
      "description": "System activity logs."
    }
  }
}
